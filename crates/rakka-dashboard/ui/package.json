{
  "name": "rakka-dashboard-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React + Vite single-page app for the rakka dashboard",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
